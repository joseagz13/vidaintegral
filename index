function renderPillars(){
  const g=document.getElementById('pil-grid');
  g.innerHTML=pillars.map((p,i)=>`
    <div class="pillar" id="pp${i}" onclick="selPillar(${i})" style="border-color:${p.color}33">
      <div class="p-dot" style="background:${p.bg};color:${p.tc}">${i+1}</div>
      <div class="p-name">${p.name}</div>
      <div class="p-sub">${p.sub}</div>
    </div>`).join('');
}

function selPillar(i){
  document.querySelectorAll('.pillar').forEach((c,j)=>{
    if(j===i){c.classList.add('sel');c.style.borderColor=pillars[i].color}
    else{c.classList.remove('sel');c.style.borderColor=pillars[j].color+'33'}
  });
  const p=pillars[i];
  document.getElementById('pil-detail').innerHTML=`
    <div style="font-size:13px;font-weight:500;color:${p.color};margin-bottom:8px">${p.name}</div>
    <div style="font-size:12px;color:var(--color-text-secondary);line-height:1.7;margin-bottom:12px">${p.desc}</div>
    <div style="display:flex;flex-wrap:wrap;gap:5px">
      ${p.items.map(it=>`<span style="font-size:11px;padding:3px 10px;border-radius:99px;background:${p.bg};color:${p.tc};border:0.5px solid ${p.color}33">${it}</span>`).join('')}
    </div>`;
}

function show(id,btn){
  document.querySelectorAll('.scr').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  document.getElementById(id).classList.add('on');
  btn.classList.add('on');
}

renderDay();
renderPillars();
selPillar(0);
